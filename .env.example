# Public Supabase browser configuration for Next.js.
# Copy this file to .env.local and replace the placeholder key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Never add RESEND_API_KEY or SUPABASE_SERVICE_ROLE_KEY here.
