# Public browser configuration used by the Vite React application.
# Copy this file to .env.local and use only the Supabase publishable key.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_API_BASE_URL=/api
VITE_SITE_URL=http://127.0.0.1:3000

# One-time migration only. Obtain this connection URI from Supabase Database settings.
# Remove it after `npm run db:export:postgres` succeeds.
SUPABASE_DB_URL=postgresql://postgres.project_ref:password@host:5432/postgres

# MySQL credentials belong in /home/CPANEL_USER/oakboard-config.php on cPanel,
# never in this browser-readable Vite environment file.
