# Public browser configuration used by the Vite React application.
# Copy this file to .env.local when overriding local defaults.
VITE_API_BASE_URL=/api
VITE_SITE_URL=http://127.0.0.1:3000

# MySQL, Mailgun, and session credentials belong in
