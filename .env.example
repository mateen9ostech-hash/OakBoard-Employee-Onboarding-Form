# OakBoard environment variables
# Copy this file to .env for local development, or add these names in
# Vercel: Project Settings > Environment Variables.

# Public browser configuration (safe to expose to the frontend)
SUPABASE_URL=https://avdwwlwxmnuqphxlpgrn.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Email delivery (server-side only)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@your-verified-domain.com

# Supabase Edge Function only. Supabase provides these automatically.
# Do not add the service-role key to frontend or public Vercel variables.
SUPABASE_SERVICE_ROLE_KEY=provided_automatically_by_supabase
