# Public Supabase browser configuration for Next.js.
# Copy this file to .env.local and replace the placeholder key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Plan storage backend. Keep `supabase` until the cPanel import is complete,
# then set this to `mysql` in the cPanel Node.js environment.
PLAN_DATABASE_BACKEND=supabase
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=your_cpanel_database_name
MYSQL_USER=your_cpanel_database_user
MYSQL_PASSWORD=your_private_database_password

# One-time migration only. Obtain this connection URI from Supabase Database settings.
# Remove it after `npm run db:export:postgres` succeeds.
SUPABASE_DB_URL=postgresql://postgres.project_ref:password@host:5432/postgres

# Public canonical URL used by metadata, sitemap.xml, and robots.txt.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Never commit real MySQL, Resend, or Supabase secret values.
