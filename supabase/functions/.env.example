# Supabase Edge Function environment variables
# Configure these with Supabase secrets; do not expose them to the React app.

RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@your-verified-domain.com

# Supabase provides this automatically to deployed Edge Functions.
# Do not add the service-role key to frontend or public Vercel variables.
SUPABASE_SERVICE_ROLE_KEY=provided_automatically_by_supabase
