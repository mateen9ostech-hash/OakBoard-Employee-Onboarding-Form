{
  "name": "oakboard-employee-onboarding-form",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=20.19 <25",
    "npm": ">=10 <12"
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "php -S 127.0.0.1:8080 -t api api/router.php",
    "build": "vite build",
    "postbuild": "node scripts/prepare-cpanel-dist.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "php:check": "node scripts/check-php.mjs",
    "db:export:postgres": "node --env-file=.env.local scripts/export-postgres-data.mjs",
    "db:import:mysql": "node --env-file=.env.local scripts/import-mysql-data.mjs"
  },
  "dependencies": {
    "@fontsource-variable/raleway": "^5.3.0",
    "@supabase/supabase-js": "^2.110.7",
    "@vonage/vivid": "^5.24.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "mysql2": "^3.23.1",
    "php-parser": "^3.2.5",
    "pg": "^8.22.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
